# ============================================================
# CS Analyzer — Required Environment Variables
# Copy this file to langchain/.env and fill in your values
# ============================================================

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- SQL Server Connection ---
IP_ADDRESS=192.168.0.50
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- CS Analyzer specific database ---
CS_DATABASE=VendorPortal_New

# --- Server (optional) ---
# CS_ANALYZER_PORT=8001   # default: 8001
# DEV_MODE=1              # enable hot-reload (development only, never set on EC2)
